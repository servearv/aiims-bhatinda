# SECRET_KEY: Required for securing Flask sessions.
# Generate a random string for production (e.g., `python -c "import secrets; print(secrets.token_hex(32))"`)
SECRET_KEY="super-secret-key"

# GEMINI_API_KEY: Required if using the external AI Studio integrations / Digitise app
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# DATABASE_PATH: Optional. Overrides the default database location.
# DATABASE_PATH="./data/database.db"
